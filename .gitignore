# Raw data — too large for version control
# (data/raw/* not data/raw/ so the negations below can re-include specific files;
# git cannot re-include a file whose parent directory is itself fully excluded)
data/raw/*
!data/raw/README.md
!data/raw/_download_log.csv

# R artifacts
.Rhistory
.RData
.Rproj.user/

# OS files
.DS_Store
Thumbs.db

# Large processed files (add exceptions below as needed)
data/processed/*.csv
data/crosswalks/*.csv

# dmr analysis/ intermediates — multi-GB, rebuilt from data/raw/ + dmr analysis/*.R
dmr analysis/*.csv

# Generated summary / flag outputs (rebuilt from scripts) — incl. nested subfolders
output/*.xlsx
output/*.csv
output/tables/*.csv
output/**/*.csv
output/**/*.xlsx

# Excel temporary lock files
~$*

# R app history
.Rapp.history

# Cloned external reference material (its own git repo; refresh with `git pull`)
lab-guide-wiki/
